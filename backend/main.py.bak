# PDF Certificate Generation
# ═══════════════════════════════════════════════════════════════════════════════

@app.post("/api/generate-certificate")
def generate_certificate():
    """Generate PDF summary certificate with all metrics and ethics findings."""
    try:
        from reportlab.lib.pagesizes import A4
        from reportlab.lib import colors
        from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
        from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, HRFlowable
        from reportlab.lib.units import cm
        from reportlab.lib.colors import HexColor
    except ImportError:
        raise HTTPException(500, "reportlab not installed")

    if not STATE["last_metrics"]:
        raise HTTPException(400, "No model trained yet")

    buf = io.BytesIO()
    doc = SimpleDocTemplate(buf, pagesize=A4,
                            rightMargin=2*cm, leftMargin=2*cm,
                            topMargin=2*cm, bottomMargin=2*cm)

    navy = HexColor("#0D2340")
    teal = HexColor("#0E9E8E")
    good_clr = HexColor("#0D7A50")
    warn_clr = HexColor("#A05C00")
    bad_clr = HexColor("#B91C1C")

    styles = getSampleStyleSheet()
    title_style = ParagraphStyle("title", fontName="Helvetica-Bold", fontSize=20, textColor=navy, spaceAfter=6)
    h2_style = ParagraphStyle("h2", fontName="Helvetica-Bold", fontSize=13, textColor=navy, spaceBefore=14, spaceAfter=4)
    body_style = ParagraphStyle("body", fontName="Helvetica", fontSize=10, textColor=HexColor("#0D1B2A"), spaceAfter=3, leading=14)
    small_style = ParagraphStyle("small", fontName="Helvetica", fontSize=9, textColor=HexColor("#4A6070"))

    domain = DOMAINS[STATE["domain"]]
    metrics = STATE["last_metrics"]
    model_name = STATE["active_model_name"].upper()
    from datetime import datetime
    ts = datetime.now().strftime("%d %B %Y, %H:%M")

    story = []

    # Header
    story.append(Paragraph("HEALTH-AI ML Tool", title_style))
    story.append(Paragraph(f"Clinical ML Certificate — {domain['label']}", h2_style))
    story.append(Paragraph(f"Generated: {ts} &nbsp;|&nbsp; Model: {model_name} &nbsp;|&nbsp; Domain: {domain['label']}", small_style))
    story.append(Spacer(1, 0.3*cm))
    story.append(HRFlowable(width="100%", thickness=2, color=teal))
    story.append(Spacer(1, 0.3*cm))

    # Performance metrics table
    story.append(Paragraph("Model Performance Metrics", h2_style))
    m_data = [
        ["Metric", "Value", "Threshold", "Status"],
        ["Accuracy", f"{metrics.get('accuracy','N/A')}%", "≥ 75%", "✓" if (metrics.get("accuracy") or 0) >= 75 else "✗"],
        ["Sensitivity (Recall)", f"{metrics.get('sensitivity','N/A')}%", "≥ 50%", "✓" if (metrics.get("sensitivity") or 0) >= 50 else "✗"],
        ["Precision", f"{metrics.get('precision','N/A')}%", "≥ 60%", "✓" if (metrics.get("precision") or 0) >= 60 else "✗"],
        ["Specificity", f"{metrics.get('specificity','N/A')}%", "≥ 60%", "✓" if (metrics.get("specificity") or 0) >= 60 else "✗"],
        ["F1 Score", str(metrics.get('f1','N/A')), "≥ 0.65", "✓" if (metrics.get("f1") or 0) >= 0.65 else "✗"],
        ["AUC-ROC", str(metrics.get('auc','N/A')), "≥ 0.70", "✓" if (metrics.get("auc") or 0) >= 0.70 else "✗"],
    ]
    t = Table(m_data, colWidths=[5*cm, 3*cm, 3*cm, 2.5*cm])
    t.setStyle(TableStyle([
        ("BACKGROUND", (0,0), (-1,0), navy),
        ("TEXTCOLOR", (0,0), (-1,0), colors.white),
        ("FONTNAME", (0,0), (-1,0), "Helvetica-Bold"),
        ("FONTSIZE", (0,0), (-1,-1), 9),
        ("ROWBACKGROUNDS", (0,1), (-1,-1), [HexColor("#F7F9FB"), colors.white]),
        ("GRID", (0,0), (-1,-1), 0.5, HexColor("#DDE4EA")),
        ("ALIGN", (1,0), (-1,-1), "CENTER"),
        ("TOPPADDING", (0,0), (-1,-1), 5),
        ("BOTTOMPADDING", (0,0), (-1,-1), 5),
    ]))
    story.append(t)

    # EU AI Act Checklist
    story.append(Paragraph("EU AI Act Compliance Checklist", h2_style))
    checklist = [
        "Risk classification documented (Article 9)",
        "Training data quality assured (Article 10)",
        "Technical documentation maintained (Article 11)",
        "Transparency obligations met (Article 13)",
        "Human oversight mechanisms enabled (Article 14)",
        "Accuracy and robustness validated (Article 15)",
        "Bias and fairness assessment completed",
        "Post-market monitoring plan in place",
    ]
    for i, item in enumerate(checklist):
        status = "✓ Pre-checked" if i < 2 else "☐ Pending review"
        story.append(Paragraph(f"{'✓' if i < 2 else '☐'} {item}", body_style))

    # Bias summary
    story.append(Paragraph("Fairness & Bias Summary", h2_style))
    story.append(Paragraph(
        f"Domain: {domain['label']} | Target: {domain['target']} | Model: {model_name}",
        body_style
    ))
    story.append(Paragraph(
        "Subgroup sensitivity analysis performed across Age and Gender groups. "
        "Groups with > 10 percentage point gap trigger automatic Bias Alert Banner.",
        body_style
    ))

    # Clinical sense-check
    story.append(Paragraph("Clinical Sense-Check", h2_style))
    story.append(Paragraph(domain["sense_check"], body_style))

    # Footer
    story.append(Spacer(1, 0.5*cm))
    story.append(HRFlowable(width="100%", thickness=1, color=HexColor("#DDE4EA")))
    story.append(Paragraph("This certificate is generated for educational purposes only and does not constitute medical advice.", small_style))

    doc.build(story)
    buf.seek(0)
    return StreamingResponse(buf, media_type="application/pdf",
                             headers={"Content-Disposition": f"attachment; filename=ml-certificate-{STATE['domain']}.pdf"})

