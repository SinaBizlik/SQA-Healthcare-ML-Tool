@app.get("/api/metrics")
def get_metrics():
    if not STATE["last_metrics"]:
        raise HTTPException(400, "No model trained yet")
    return STATE["last_metrics"]

@app.get("/api/metrics/color/{value}")
def metric_colour(value: float):
    if value >= 70:
        return {"color": "good"}
    elif value >= 50:
        return {"color": "warn"}
    else:
        return {"color": "bad"}

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 6 — Explainability
# ═══════════════════════════════════════════════════════════════════════════════

@app.get("/api/feature-importance")
def feature_importance():
    if STATE["model"] is None:
        raise HTTPException(400, "No model trained yet")
    clf = STATE["model"]
    feature_names = STATE["feature_names"]

    importances = None
    method = "unknown"

    if hasattr(clf, "feature_importances_"):
        importances = clf.feature_importances_
        method = "gini_importance"
    elif hasattr(clf, "coef_"):
        importances = np.abs(clf.coef_[0]) if clf.coef_.ndim > 1 else np.abs(clf.coef_)
        method = "coefficient_magnitude"
    else:
        # Permutation-like: use feature std as proxy
        if STATE["X_train"] is not None:
            importances = np.std(STATE["X_train"], axis=0)
            method = "feature_variance"
        else:
            importances = np.ones(len(feature_names))
            method = "uniform"

    # Normalize to [0, 1]
    total = importances.sum()
    if total > 0:
        importances = importances / total
    else:
        importances = np.ones(len(feature_names)) / len(feature_names)

    # Sort descending
    sorted_idx = np.argsort(importances)[::-1]
    result = [
        {"feature": feature_names[i], "importance": round(float(importances[i]), 4)}
        for i in sorted_idx
    ]
    return {"importances": result, "method": method, "model": STATE["active_model_name"]}

@app.get("/api/waterfall/{patient_idx}")
def waterfall(patient_idx: int = 0):
    """Waterfall chart for a single patient (SHAP-like approximation)."""
    if STATE["model"] is None or STATE["X_test"] is None:
        raise HTTPException(400, "Model not trained yet")

    X_test = STATE["X_test"]
    if patient_idx >= len(X_test):
        raise HTTPException(400, f"Patient index {patient_idx} out of range")

    clf = STATE["model"]
    feature_names = STATE["feature_names"]
    patient = X_test[patient_idx]
    base_prob = float(np.mean(clf.predict_proba(STATE["X_train"])[:, 1])) if hasattr(clf, "predict_proba") else 0.5

    # Approximate contributions via marginal differences
    contribs = []
    pred_prob = float(clf.predict_proba(patient.reshape(1, -1))[0, 1]) if hasattr(clf, "predict_proba") else float(clf.predict(patient.reshape(1, -1))[0])

    # Distribute prediction - base across features proportional to value magnitude
    total_magnitude = np.sum(np.abs(patient))
    if total_magnitude == 0:
        total_magnitude = 1.0

    delta = pred_prob - base_prob
    contributions = patient * np.abs(patient) / (total_magnitude + 1e-9) * delta

    for i, feat in enumerate(feature_names):
        contribs.append({
            "feature": feat,
            "value": round(float(patient[i]), 3),
            "contribution": round(float(contributions[i]), 4),
        })

    # Sort by abs contribution
    contribs.sort(key=lambda x: abs(x["contribution"]), reverse=True)

    return {
        "patient_index": patient_idx,
        "base_probability": round(base_prob, 4),
        "predicted_probability": round(pred_prob, 4),
        "contributions": contribs[:10],
        "n_patients": len(X_test),
    }

@app.get("/api/patients")
def get_patients():
    """Return list of test patients for waterfall selector."""
    if STATE["X_test"] is None or STATE["y_test"] is None:
        raise HTTPException(400, "Model not trained yet")
    clf = STATE["model"]
    X_test = STATE["X_test"]
    y_test = STATE["y_test"]
    probs = clf.predict_proba(X_test)[:, 1] if hasattr(clf, "predict_proba") else clf.predict(X_test).astype(float)
    domain = DOMAINS[STATE["domain"]]
    patients = []
    for i in range(min(10, len(X_test))):
        patients.append({
            "index": i,
            "label": f"Patient {i+1}",
            "true_label": domain["positive_label"] if int(y_test[i]) == 1 else domain["negative_label"],
            "predicted_prob": round(float(probs[i]), 3),
        })
    return {"patients": patients}

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 7 — Ethics, Bias, EU AI Act
# ═══════════════════════════════════════════════════════════════════════════════

@app.get("/api/subgroup-analysis")
def subgroup_analysis():
    """Compute sensitivity by simulated age/gender subgroups."""
    if STATE["model"] is None or STATE["X_test"] is None:
        raise HTTPException(400, "Model not trained")

    clf = STATE["model"]
    X_test = STATE["X_test"]
    y_test = STATE["y_test"]
    rng = np.random.RandomState(99)

    n = len(y_test)
    # Simulate demographic groups
    age_groups = rng.choice(["18–40", "41–60", "61–80", "80+"], n, p=[0.2, 0.35, 0.35, 0.1])
    gender_groups = rng.choice(["Male", "Female"], n, p=[0.5, 0.5])

    y_pred = clf.predict(X_test)
    rows = []

    # Age subgroups
    for grp in ["18–40", "41–60", "61–80", "80+"]:
        mask = age_groups == grp
        if mask.sum() == 0:
            continue
        sens = round(recall_score(y_test[mask], y_pred[mask], zero_division=0) * 100, 1)
        rows.append({"group": grp, "type": "Age", "n": int(mask.sum()),
                     "sensitivity": sens, "ok": sens >= 50})

    # Gender subgroups
    for grp in ["Male", "Female"]:
        mask = gender_groups == grp
        if mask.sum() == 0:
            continue
        sens = round(recall_score(y_test[mask], y_pred[mask], zero_division=0) * 100, 1)
        rows.append({"group": grp, "type": "Gender", "n": int(mask.sum()),
                     "sensitivity": sens, "ok": sens >= 50})

    # Check bias: any gap > 10pp within same type
    def max_gap(rows_of_type):
        vals = [r["sensitivity"] for r in rows_of_type]
        return max(vals) - min(vals) if len(vals) > 1 else 0

    age_rows = [r for r in rows if r["type"] == "Age"]
    gen_rows = [r for r in rows if r["type"] == "Gender"]
    bias_detected = max_gap(age_rows) > 10 or max_gap(gen_rows) > 10
    age_gap = round(max_gap(age_rows), 1)
    gender_gap = round(max_gap(gen_rows), 1)

    return {
        "rows": rows,
        "bias_detected": bias_detected,
        "age_gap": age_gap,
        "gender_gap": gender_gap,
        "bias_threshold": 10,
    }

@app.get("/api/training-data-chart")
def training_data_chart():
    """Training vs population distribution comparison."""
    if STATE["X_train"] is None:
        raise HTTPException(400, "Model not trained")
    domain = DOMAINS[STATE["domain"]]
    feature_names = STATE["feature_names"]
    X_train = STATE["X_train"]

    # Simulate population baseline
    rng = np.random.RandomState(1)
    X_pop = rng.randn(*X_train.shape)

    chart_data = []
    for i, feat in enumerate(feature_names[:6]):
        chart_data.append({
            "feature": feat,
            "training_mean": round(float(np.mean(X_train[:, i])), 3),
            "population_mean": round(float(np.mean(X_pop[:, i])), 3),
            "gap_pp": round(abs(float(np.mean(X_train[:, i])) - float(np.mean(X_pop[:, i]))) * 100 / max(abs(float(np.mean(X_pop[:, i]))), 0.01), 1),
        })
    return {"chart_data": chart_data}

