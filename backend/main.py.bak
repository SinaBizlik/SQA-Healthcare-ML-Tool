# ─── Helper: generate synthetic dataset ───────────────────────────────────────
def generate_synthetic_data(domain_key: str, n: int = 304) -> pd.DataFrame:
    rng = np.random.RandomState(42)
    domain = DOMAINS[domain_key]
    features = domain["features"]
    n_features = len(features)

    # Generate realistic-ish data with some correlation structure
    X = rng.randn(n, n_features)
    # Add some missing values (~5%) for realism
    mask = rng.random((n, n_features)) < 0.05
    X_with_missing = X.astype(float)
    X_with_missing[mask] = np.nan

    # Target: logistic combination of first two features
    logit = X[:, 0] * 1.2 + X[:, 1] * 0.8 + rng.randn(n) * 0.6
    y = (logit > 0.3).astype(int)

    # Use technical names as column names (clinical names assigned via mapper)
    tech_cols = [f"feat_{i}" for i in range(n_features)]
    df = pd.DataFrame(X_with_missing, columns=tech_cols)
    df["target"] = y
    return df


def _build_upload_response(df: pd.DataFrame, domain_key: str) -> dict:
    """Shared helper to build the upload response dict from a dataframe."""
    domain = DOMAINS[domain_key]
    clinical_features = domain["features"]
    cols = df.columns.tolist()

    # Auto-map feat_0 → clinical_features[0], etc.
    auto_map = {}
    for i, col in enumerate(cols[:-1]):
        auto_map[col] = clinical_features[i] if i < len(clinical_features) else col
    target_col = cols[-1]

    missing_info = {col: int(df[col].isna().sum()) for col in cols if df[col].isna().any()}

    stats = []
    for col in cols:
        if pd.api.types.is_numeric_dtype(df[col]):
            non_null = df[col].dropna()
            stats.append({
                "column": col,
                "clinical_name": auto_map.get(col, col),
                "dtype": "numeric",
                "missing": int(df[col].isna().sum()),
                "mean": round(float(non_null.mean()), 3) if len(non_null) else 0,
                "std":  round(float(non_null.std()),  3) if len(non_null) else 0,
                "min":  round(float(non_null.min()),  3) if len(non_null) else 0,
                "max":  round(float(non_null.max()),  3) if len(non_null) else 0,
            })
        else:
            stats.append({
                "column": col,
                "clinical_name": auto_map.get(col, col),
                "dtype": "categorical",
                "missing": int(df[col].isna().sum()),
                "unique": int(df[col].nunique()),
            })

    preview = df.head(5).fillna("N/A").to_dict(orient="records")
    return {
        "columns": cols,
        "n_rows": len(df),
        "n_cols": len(cols),
        "auto_mapping": auto_map,
        "suggested_target": target_col,
        "missing_info": missing_info,
        "stats": stats,
        "preview": preview,
        "clinical_features": clinical_features,
    }

# ─── Pydantic models ──────────────────────────────────────────────────────────
class ColumnMapping(BaseModel):
    mapping: Dict[str, str]  # technical_col → clinical_name
    target_col: str

class PrepareRequest(BaseModel):
    normalization: str = "standard"  # standard | minmax | none
    handle_missing: str = "mean"     # mean | median | drop
    apply_smote: bool = False
    test_size: float = 0.2

class TrainRequest(BaseModel):
    model_name: str = "knn"
    params: Dict[str, Any] = {}

class SubgroupRequest(BaseModel):
    age_col: Optional[str] = None
    gender_col: Optional[str] = None

